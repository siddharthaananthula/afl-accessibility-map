# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data (keep raw downloads local, processed in repo if small)
data/raw/*
!data/raw/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Outputs (keep final, ignore intermediate)
outputs/temp/
*.log

# Environment
.env
*.env

# OSMnx cache (transient API response cache, don't commit)
cache/

# Large OSM PBF dumps (downloaded automatically, don't commit)
*.osm.pbf

# Large geospatial outputs (regeneratable from pipeline)
data/raw/*.geojson
data/raw/*.osm.pbf

# Keep small CSVs and the gitkeep
!data/raw/.gitkeep
!data/raw/*.csv